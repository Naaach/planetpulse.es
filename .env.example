# ============================================
# PLANET PULSE — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --- Proxy URL (optional) ---
# The frontend now falls back to "/api/data" (same origin) when unset,
# which works out of the box on Cloudflare Pages (via functions/api/data.js).
# Only needed for local dev with the Node proxy:
#   PUBLIC_API_PROXY=http://localhost:3001/api/data

# --- Proxy server port (only used by server/proxy.mjs) ---
# PROXY_PORT=3001
