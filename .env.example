# ============================================
# PLANET PULSE — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --- Proxy server (recommended) ---
# When set, the frontend fetches from this URL instead of calling external APIs.
# The server fetches from APIs, caches 5min, and returns combined data.
# Example (local dev): http://localhost:3001/api/data
# PUBLIC_API_PROXY=http://localhost:3001/api/data

# --- Proxy server port (only used by server/proxy.mjs) ---
PROXY_PORT=3001
