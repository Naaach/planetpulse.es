---
import BaseLayout from '../layouts/BaseLayout.astro';
import MedidorGrid from '../components/MedidorGrid.astro';
---

<BaseLayout>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 lg:py-16">
    <header class="text-center mb-10 sm:mb-14">
      <div class="flex justify-center mb-5">
        <div class="inline-flex items-center gap-1 p-0.5 rounded-xl bg-[#e5ddd3]/50 border border-[#e5ddd3]/60" role="group" aria-label="Language">
          <button data-lang-btn="es" class="lang-btn" aria-pressed="true">ES</button>
          <button data-lang-btn="en" class="lang-btn" aria-pressed="false">EN</button>
        </div>
      </div>

      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-normal text-[#1c1c28] tracking-tight font-heading">
        <span class="lang-es">Planeta en tiempo real</span>
        <span class="lang-en">Planet in Real Time</span>
      </h1>
      <div class="w-12 h-0.5 bg-gradient-to-r from-leaf-700 via-[#d4a373] to-transparent mx-auto mt-4 mb-4 rounded-full"></div>
      <p class="text-base sm:text-lg text-stone-500 max-w-2xl mx-auto font-light leading-relaxed">
        <span class="lang-es">Datos ambientales globales actualizados: temperatura, CO₂, calidad del aire por ciudad y más indicadores climáticos en directo.</span>
        <span class="lang-en">Real-time global environmental data: temperature, CO₂, city air quality and more climate indicators live.</span>
      </p>
    </header>

    <div class="bg-[#efe9de]/80 border border-[#ddd6cc] rounded-xl px-4 py-3 mb-10 sm:mb-12 text-sm text-[#5c5042]" role="note" aria-label="Information">
      <p class="flex items-start gap-2.5">
        <svg class="w-5 h-5 mt-0.5 shrink-0 text-stone-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="12" x2="12" y2="16"/>
          <line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        <span>
          <span class="lang-es">Explora datos climáticos actualizados de <strong>NASA, NOAA, Copernicus</strong> y otras fuentes. Haz clic en <strong>&laquo;Ver datos técnicos&raquo;</strong> dentro de cada tarjeta para conocer fuentes, rangos históricos y detalles de cada medición ambiental.</span>
          <span class="lang-en">Explore climate data from <strong>NASA, NOAA, Copernicus</strong> and other sources. Click <strong>&laquo;View technical data&raquo;</strong> inside each card to see sources, historical ranges, and details for each environmental measurement.</span>
        </span>
      </p>
    </div>

    <div class="mb-8 sm:mb-10">
      <div class="flex items-center justify-center gap-2 text-sm text-stone-500 mb-3">
        <span aria-hidden="true" style="font-size: 0.9rem;">🗺</span>
        <span class="lang-es font-medium text-[#5c5042]">Ciudad:</span>
        <span class="lang-en font-medium text-[#5c5042]">City:</span>
        <span data-city-label class="font-semibold text-[#1c1c28]">—</span>
      </div>
      <div data-city-chips class="city-chips"></div>
    </div>

    <div class="flex items-center justify-center gap-3 mb-8 sm:mb-10">
      <button
        data-refresh-btn
        class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-xl bg-[#1c1c28] text-white text-sm font-medium hover:bg-[#3d352c] transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#2d6a4f] shadow-sm"
        type="button"
        aria-label="Refresh data"
      >
        <svg class="w-4 h-4 refresh-icon" data-refresh-icon viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="23 4 23 10 17 10"/>
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
        <span class="lang-es">Actualizar</span>
        <span class="lang-en">Refresh</span>
      </button>
      <span class="text-xs text-stone-500" data-last-update></span>
    </div>

    <MedidorGrid />
  </main>
</BaseLayout>

<style is:global>
  .city-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    padding: 0.25rem 0 0.5rem;
  }
  .city-chip {
    padding: 0.4rem 0.9rem 0.4rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 500;
    background: #eae6e0;
    color: #5c5042;
    border: 1px solid #ddd6cc;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
    line-height: 1.5;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .city-chip:hover {
    background: #ddd6cc;
    border-color: #ccc2b5;
    box-shadow: 0 2px 6px rgba(0,0,0,0.07);
  }
  .city-chip.active {
    background: #2d6a4f;
    color: #fff;
    border-color: #2d6a4f;
    box-shadow: 0 2px 8px rgba(45,106,79,0.3);
  }
  .city-chip .chip-flag {
    font-size: 1em;
    line-height: 1;
  }
  @media (max-width: 480px) {
    .city-chip {
      padding: 0.3rem 0.7rem 0.3rem 0.55rem;
      font-size: 0.72rem;
      gap: 0.2rem;
    }
  }
</style>