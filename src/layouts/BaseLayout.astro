<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Planet Pulse — Datos ambientales globales en tiempo real</title>
    <meta name="description" content="Planet Pulse muestra medidores ambientales globales en tiempo real: temperatura, CO₂, calidad del aire por ciudad y más. Datos claros del planeta, actualizados." />
    <meta name="keywords" content="cambio climático, calidad del aire, CO2, temperatura global, nivel del mar, energía renovable, índice UV, datos ambientales" />
    <meta name="theme-color" content="#f5f7fa" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Planet Pulse" />

    <meta property="og:title" content="Planet Pulse — Estado del planeta en tiempo real" />
    <meta property="og:description" content="Temperatura global, CO₂, calidad del aire por ciudad y más medidores ambientales actualizados en tiempo real." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://planetpulse.es" />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Planet Pulse — Estado del planeta en tiempo real" />
    <meta name="twitter:description" content="Temperatura global, CO₂, calidad del aire por ciudad y más medidores ambientales actualizados en tiempo real." />

    <link rel="canonical" href="https://planetpulse.es" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script>
      (function () {
        var lang = localStorage.getItem('planetpulse-lang');
        if (lang === 'en') document.documentElement.lang = 'en';
      })();
    </script>
    <style is:global>
      html:not([lang="es"]) .lang-es { display: none !important; }
      html:not([lang="en"]) .lang-en { display: none !important; }

      .tooltip-trigger {
        position: relative;
        display: inline-flex;
        align-items: center;
        cursor: help;
      }
      .tooltip-trigger .tooltip-text {
        position: absolute;
        bottom: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%);
        background: #1f2937;
        color: #fff;
        font-size: 0.75rem;
        line-height: 1.3;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        width: max-content;
        max-width: 280px;
        text-align: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.15s ease;
        z-index: 20;
        box-shadow: 0 4px 16px rgba(0,0,0,0.18);
      }
      .tooltip-trigger .tooltip-text::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 6px solid transparent;
        border-top-color: #1f2937;
      }
      .tooltip-trigger:hover .tooltip-text,
      .tooltip-trigger:focus-visible .tooltip-text {
        opacity: 1;
      }

      .lang-btn {
        padding: 0.25rem 0.625rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        transition: all 0.15s ease;
        cursor: pointer;
        border: 1px solid transparent;
      }
      .lang-btn:focus-visible {
        outline: 2px solid #9ca3af;
        outline-offset: 2px;
      }
    </style>
  </head>
  <body class="bg-[#f5f7fa] font-sans text-gray-900 antialiased min-h-screen flex flex-col">
    <slot />

    <footer class="mt-auto py-10 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <div class="w-8 h-8 mx-auto mb-4 opacity-30">
          <svg viewBox="0 0 32 32" fill="none">
            <circle cx="16" cy="16" r="14" fill="currentColor"/>
          </svg>
        </div>
        <p class="text-sm text-gray-400 max-w-xl mx-auto leading-relaxed">
          <span class="lang-es">Los datos pueden variar seg&uacute;n la fuente. Actualizaci&oacute;n peri&oacute;dica.</span>
          <span class="lang-en">Data may vary by source. Updated periodically.</span>
        </p>
        <p class="text-xs text-gray-300 mt-2">
          <span class="lang-es">Planet Pulse &mdash; Datos ambientales globales</span>
          <span class="lang-en">Planet Pulse &mdash; Global environmental data</span>
        </p>

        <div class="mt-6">
          <button data-contact-toggle class="inline-flex items-center gap-1.5 text-xs text-gray-300 hover:text-gray-500 transition-colors cursor-pointer">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <span class="lang-es">Contacto</span>
            <span class="lang-en">Contact</span>
          </button>

          <div data-contact-form class="hidden mt-4 max-w-md mx-auto">
            <p data-contact-status class="text-xs text-gray-400 mb-2"></p>
            <form class="flex flex-col sm:flex-row gap-2">
              <input type="email" name="email" required placeholder="tu@email.com" class="flex-1 px-3 py-2 text-xs rounded-lg border border-gray-200 bg-white text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-300" />
              <textarea name="message" required placeholder="Mensaje / Message" rows="1" class="flex-1 px-3 py-2 text-xs rounded-lg border border-gray-200 bg-white text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-300 resize-none"></textarea>
              <button type="submit" class="px-4 py-2 text-xs rounded-lg bg-gray-200 text-gray-600 hover:bg-gray-300 transition-colors shrink-0">
                <span class="lang-es">Enviar</span>
                <span class="lang-en">Send</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        var lang = document.documentElement.lang || 'es';

        document.querySelectorAll('[data-lang-btn]').forEach(function (btn) {
          var isActive = btn.getAttribute('data-lang-btn') === lang;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');

          btn.addEventListener('click', function () {
            var newLang = this.getAttribute('data-lang-btn');
            document.documentElement.lang = newLang;
            localStorage.setItem('planetpulse-lang', newLang);
            document.querySelectorAll('[data-lang-btn]').forEach(function (b) {
              var active = b.getAttribute('data-lang-btn') === newLang;
              b.classList.toggle('active', active);
              b.setAttribute('aria-pressed', active ? 'true' : 'false');
            });
          });
        });

        var toggle = document.querySelector('[data-contact-toggle]');
        var formWrap = document.querySelector('[data-contact-form]');
        var statusEl = document.querySelector('[data-contact-status]');
        if (toggle && formWrap) {
          toggle.addEventListener('click', function () {
            formWrap.classList.toggle('hidden');
          });

          formWrap.querySelector('form').addEventListener('submit', function (e) {
            e.preventDefault();
            var form = e.target;
            var data = { email: form.email.value, message: form.message.value, _subject: 'Planet Pulse - Contacto' };
            statusEl.textContent = 'Enviando... / Sending...';
            statusEl.className = 'text-xs text-gray-400 mb-2';
            fetch('https://formsubmit.co/ajax/nach704@gmail.com', {
              method: 'POST',
              body: JSON.stringify(data),
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }
            }).then(function (r) { return r.json(); }).then(function () {
              statusEl.textContent = 'Enviado! Gracias / Sent! Thank you';
              statusEl.className = 'text-xs text-green-600 mb-2';
              form.reset();
            }).catch(function () {
              var es = document.documentElement.lang === 'es';
              statusEl.textContent = es ? 'Error al enviar. Intenta de nuevo.' : 'Send error. Try again.';
              statusEl.className = 'text-xs text-red-500 mb-2';
            });
          });
        }
      });
    </script>
  </body>
</html>
