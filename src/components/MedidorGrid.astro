<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 sm:gap-6">
  {medidores.map((m, i) => (
    <Medidor
      tituloES={m.tituloES}
      tituloEN={m.tituloEN}
      tooltipES={m.tooltipES}
      tooltipEN={m.tooltipEN}
      valor={m.valor}
      unidad={m.unidad}
      tendencia={m.tendencia}
      porcentaje={m.porcentaje}
      trendText={m.trendText}
      icono={m.icono}
      fuenteES={m.fuenteES}
      fuenteEN={m.fuenteEN}
      rangoHistoricoES={m.rangoHistoricoES}
      rangoHistoricoEN={m.rangoHistoricoEN}
      detalleTecnicoES={m.detalleTecnicoES}
      detalleTecnicoEN={m.detalleTecnicoEN}
      notaES={m.notaES}
      notaEN={m.notaEN}
      actualizacionES={m.actualizacionES}
      actualizacionEN={m.actualizacionEN}
      color={m.color}
      index={i}
    />
  ))}
</div>

<script>
  import { initDataUpdater } from '../services/data-updater';
  initDataUpdater();
</script>
