---
const {
  tituloES,
  tituloEN,
  tooltipES,
  tooltipEN,
  valor,
  unidad,
  tendencia,
  porcentaje,
  trendText,
  icono,
  fuenteES,
  fuenteEN,
  rangoHistoricoES,
  rangoHistoricoEN,
  detalleTecnicoES,
  detalleTecnicoEN,
  notaES,
  notaEN,
  actualizacionES,
  actualizacionEN,
  color = 'neutral',
  index = 0,
} = Astro.props;

const flecha = tendencia === 'up' ? '\u2191' : tendencia === 'down' ? '\u2193' : '\u2192';
const etiquetaES = tendencia === 'up' ? 'Al alza' : tendencia === 'down' ? 'A la baja' : 'Estable';
const etiquetaEN = tendencia === 'up' ? 'Rising' : tendencia === 'down' ? 'Declining' : 'Stable';
const porcentajeDisplay = trendText || (porcentaje != null ? (porcentaje >= 0 ? `+${porcentaje}%` : `${porcentaje}%`) : '\u2014');

const colorMap = {
  bueno: { text: 'text-green-700', badge: 'bg-green-100 text-green-700' },
  malo: { text: 'text-red-600', badge: 'bg-red-100 text-red-600' },
  neutral: { text: 'text-stone-500', badge: 'bg-stone-100 text-stone-500' },
};
const c = colorMap[color] || colorMap.neutral;
---

<article class="medidor-card bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 p-6 sm:p-8 animate-fade-in opacity-0 border border-[#e5ddd3]/40" data-medidor-index={index} style={`animation-delay: ${index * 0.08}s`}>
  <div class="flex items-center gap-3 mb-4">
    <span class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#f0ece4] text-[#5c5042] shrink-0" aria-hidden="true">
      <Fragment set:html={icono} />
    </span>
    <h2 class="text-base sm:text-lg font-semibold text-[#1c1c28] flex items-center gap-2">
      <span class="lang-es">{tituloES}</span>
      <span class="lang-en">{tituloEN}</span>
      <span class="tooltip-trigger" tabindex="0" role="tooltip" aria-label={tooltipES}>
        <svg class="w-4 h-4 text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="16" x2="12" y2="12"/>
          <line x1="12" y1="8" x2="12.01" y2="8"/>
        </svg>
        <span class="tooltip-text">
          <span class="lang-es">{tooltipES}</span>
          <span class="lang-en">{tooltipEN}</span>
        </span>
      </span>
    </h2>
  </div>

  <div class="mb-1">
    <span class="inline-flex items-center gap-2">
      <span class="text-4xl sm:text-5xl font-bold text-[#1c1c28] tabular-nums tracking-tight" data-medidor-value>{valor}</span>
      <span class="text-base sm:text-lg font-medium text-stone-500 ml-1">{unidad}</span>
      <span data-live-dot class="w-2 h-2 rounded-full bg-stone-300 inline-block shrink-0" aria-hidden="true"></span>
    </span>
  </div>

  <div class="flex items-center gap-2.5 mb-5">
    <span data-medidor-badge class={`inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs sm:text-sm font-medium ${c.badge}`} aria-label={`Tendencia: ${etiquetaES}`}>
      <span aria-hidden="true">{flecha}</span>
      <span class="lang-es">{etiquetaES}</span>
      <span class="lang-en">{etiquetaEN}</span>
    </span>
    <span data-medidor-pct class={`text-sm font-medium tabular-nums ${c.text}`}>{porcentajeDisplay}</span>
  </div>

  <button
    class="tech-toggle w-full flex items-center gap-2 text-sm font-medium text-stone-500 hover:text-[#5c5042] transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#2d6a4f]/40 rounded-lg py-2"
    aria-expanded="false"
    aria-controls={`tech-data-${index}`}
    type="button"
  >
    <svg class="tech-arrow w-4 h-4 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9" />
    </svg>
    <span class="lang-es">Ver datos t&eacute;cnicos</span>
    <span class="lang-en">View technical data</span>
  </button>

  <div id={`tech-data-${index}`} class="tech-content" role="region" aria-label={`Detalle técnico de ${tituloES}`}>
    <div class="pt-5 border-t border-[#e5ddd3] space-y-4">
      <div>
        <span class="text-xs font-semibold text-stone-500 uppercase tracking-wider">
          <span class="lang-es">Fuente</span>
          <span class="lang-en">Source</span>
        </span>
        <p class="text-sm text-[#5c5042] mt-0.5 leading-relaxed">
          <span class="lang-es">{fuenteES}</span>
          <span class="lang-en">{fuenteEN}</span>
        </p>
      </div>
      <div>
        <span class="text-xs font-semibold text-stone-500 uppercase tracking-wider">
          <span class="lang-es">Rango hist&oacute;rico</span>
          <span class="lang-en">Historical range</span>
        </span>
        <p class="text-sm text-[#5c5042] mt-0.5">
          <span class="lang-es">{rangoHistoricoES}</span>
          <span class="lang-en">{rangoHistoricoEN}</span>
        </p>
      </div>
      <div>
        <span class="text-xs font-semibold text-stone-500 uppercase tracking-wider">
          <span class="lang-es">Detalle t&eacute;cnico</span>
          <span class="lang-en">Technical detail</span>
        </span>
        <p class="text-sm text-[#5c5042] mt-0.5 leading-relaxed">
          <span class="lang-es">{detalleTecnicoES}</span>
          <span class="lang-en">{detalleTecnicoEN}</span>
        </p>
      </div>
      <div>
        <span class="text-xs font-semibold text-stone-500 uppercase tracking-wider">
          <span class="lang-es">Nota</span>
          <span class="lang-en">Note</span>
        </span>
        <p class="text-sm text-stone-500 mt-0.5 leading-relaxed">
          <span class="lang-es">{notaES}</span>
          <span class="lang-en">{notaEN}</span>
        </p>
      </div>
      <div>
        <span class="text-xs font-semibold text-stone-500 uppercase tracking-wider">
          <span class="lang-es">Actualizaci&oacute;n</span>
          <span class="lang-en">Update frequency</span>
        </span>
        <p class="text-sm text-[#5c5042] mt-0.5">
          <span class="lang-es">{actualizacionES}</span>
          <span class="lang-en">{actualizacionEN}</span>
        </p>
        <p class="text-xs text-stone-500 mt-0.5" data-card-timestamp></p>
      </div>
    </div>
  </div>
</article>

<style is:global>
  .tech-content {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.3s ease, margin 0.3s ease;
    margin-top: 0;
  }
  .tech-content.is-open {
    max-height: 500px;
    opacity: 1;
    margin-top: 0.75rem;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.tech-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var card = this.closest('.medidor-card');
        if (!card) return;
        var content = card.querySelector('.tech-content');
        var arrow = this.querySelector('.tech-arrow');
        if (!content) return;

        var isOpen = content.classList.contains('is-open');

        if (isOpen) {
          content.classList.remove('is-open');
          this.setAttribute('aria-expanded', 'false');
          if (arrow) arrow.style.transform = 'rotate(0deg)';
        } else {
          content.classList.add('is-open');
          this.setAttribute('aria-expanded', 'true');
          if (arrow) arrow.style.transform = 'rotate(180deg)';
        }
      });
    });
  });
</script>